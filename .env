# ─── Unbound DNS Web GUI — Environment Configuration ──────────────────────────
# All paths and toggles the app reads from. Change here; never edit app.py paths.

# ── Unbound config paths ───────────────────────────────────────────────────────
DEFAULT_CONFIG_FILE=/etc/unbound/unbound.conf
DEFAULT_CONFIG_DIR=/etc/unbound/unbound.conf.d/

# ── Backup directory (relative to app.py or absolute) ─────────────────────────
BACKUP_DIR=./backups

# ── Unbound control certificate files (used by unbound-control) ───────────────
UNBOUND_SERVER_KEY=/etc/unbound/unbound_server.key
UNBOUND_SERVER_PEM=/etc/unbound/unbound_server.pem
UNBOUND_CONTROL_KEY=/etc/unbound/unbound_control.key
UNBOUND_CONTROL_PEM=/etc/unbound/unbound_control.pem

# ── Web GUI TLS (the GUI's own HTTPS certificate, NOT unbound's control certs) ─
# Set HTTPS_ENABLED=false if you are using nginx/caddy/traefik as a TLS-
# terminating reverse proxy. The app will then bind plain HTTP and let your
# proxy handle TLS — no code change needed.
HTTPS_ENABLED=true
HTTP_PORT=8080
HTTPS_PORT=8443
